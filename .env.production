# Public site URL (Open Graph / Twitter preview images in index.html)
VITE_SITE_ORIGIN=https://draught-game.netlify.app

# Production — set your hosted Django API (must include /api path if that is your mount point)
# Example: https://api.yourdomain.com/api
# Must include /api — Django mounts REST at /api/...
VITE_API_BASE_URL=https://draught-api.onrender.com/api
VITE_USE_GAME_WS=true
VITE_FEEDBACK_FORM_URL=https://docs.google.com/forms/d/e/1FAIpQLSfJ6QyrOP-wUx32hL2q_IT78fkEOYzS8wfkWKsqNdT0WE5pow/viewform?usp=publish-editor